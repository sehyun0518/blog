# Required — PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/blog

# Required — secret key for signing API tokens
API_KEY=replace-me-with-a-strong-random-value

# Optional — enable verbose server-side debug logging (default: false)
DEBUG=false

# Public — canonical site URL used for OG images, sitemap, and RSS feed
NEXT_PUBLIC_SITE_URL=https://example.com

# Optional — Upstash Redis for persisting like counts across sessions
# Create a free database at https://console.upstash.com and copy the REST URL and token
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional — Giscus comments (GitHub Discussions)
# Configure at https://giscus.app and paste the values below
# Comments section is hidden when these are not set
NEXT_PUBLIC_GISCUS_REPO=
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=
NEXT_PUBLIC_GISCUS_CATEGORY_ID=

{
  "name": "@blog/utils",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cn": {
      "types": "./dist/cn.d.ts",
      "import": "./dist/cn.js"
    },
    "./date": {
      "types": "./dist/date.d.ts",
      "import": "./dist/date.js"
    },
    "./string": {
      "types": "./dist/string.d.ts",
      "import": "./dist/string.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "tailwind-merge": "3.3.0",
    "zod": "3.24.3"
  },
  "devDependencies": {
    "@blog/config": "workspace:*",
    "@vitest/coverage-v8": "3.1.2",
    "typescript": "5.8.3",
    "vitest": "3.1.2"
  }
}

{
  "name": "@blog/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./button": {
      "types": "./src/components/button.tsx",
      "import": "./src/components/button.tsx"
    },
    "./card": {
      "types": "./src/components/card.tsx",
      "import": "./src/components/card.tsx"
    },
    "./badge": {
      "types": "./src/components/badge.tsx",
      "import": "./src/components/badge.tsx"
    },
    "./globals.css": "./src/globals.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@blog/utils": "workspace:*",
    "@radix-ui/react-slot": "1.2.3",
    "class-variance-authority": "0.7.1",
    "lucide-react": "0.511.0",
    "react": "19.2.5"
  },
  "devDependencies": {
    "@blog/config": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "19.2.3",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "3.1.2",
    "jsdom": "^29.0.2",
    "tailwindcss": "4.1.3",
    "typescript": "5.8.3",
    "vitest": "3.1.2"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  }
}

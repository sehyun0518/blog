{
  "name": "blog-monorepo",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=22",
    "pnpm": "10.23.0"
  },
  "type": "module",
  "packageManager": "pnpm@10.23.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:workspace": "vitest --workspace",
    "test:coverage": "vitest --workspace --coverage",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "vitest": "3.1.2"
  }
}
